#!/bin/bash

set -e -x

# Prevent shutdown during background saving
cat >/etc/sysctl.d/valkey-overcommit.conf <<"EOF"
# https://valkey.io/topics/faq/#background-saving-fails-with-a-fork-error-on-linux
#vm.overcommit_memory = 1
EOF

# Allow high backlog
cat >/etc/sysctl.d/valkey-tcp-listen-backlog.conf <<"EOF"
# https://www.kernel.org/doc/Documentation/networking/ip-sysctl.txt
##net.ipv4.tcp_max_syn_backlog = 512
#net.core.somaxconn = 512
EOF

# Valkey - high-performance key/value datastore
Pkg_install_quiet valkey-server

# allkeys-lru, 512 MB memory usage
sed -i -e 's|^#\s*maxmemory-policy .*$|maxmemory-policy allkeys-lru|' /etc/valkey/valkey.conf
sed -i -e 's|^#\s*maxmemory .*$|maxmemory 512mb|' /etc/valkey/valkey.conf

# Check server
echo "FLUSHALL" | nc -C -q 3 localhost 6379
